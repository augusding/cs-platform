# CS Platform 环境配置
# 复制此文件为 .env，填写真实值。.env 文件禁止提交到 git。

# ─── 应用基础配置 ─────────────────────────────────────────
APP_ENV=development          # development | staging | production
APP_HOST=0.0.0.0
APP_PORT=8080
DEBUG=true                   # production 时必须设为 false
LOG_LEVEL=INFO

# ─── JWT 配置 ─────────────────────────────────────────────
JWT_SECRET=your-256-bit-secret-key-change-this-in-production
JWT_ACCESS_TOKEN_EXPIRE_SECONDS=900       # 15分钟
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── 数据库配置 ───────────────────────────────────────────
DATABASE_URL=postgresql://cs_user:cs_pass@localhost:5432/cs_platform
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# ─── Redis 配置 ───────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_DB=0             # 缓存用 DB 0
REDIS_QUEUE_DB=1             # RQ 队列用 DB 1

# ─── Milvus 配置 ──────────────────────────────────────────
MILVUS_HOST=localhost
MILVUS_PORT=19530

# ─── AI 配置 ──────────────────────────────────────────────
# 主力 LLM（通义千问）
QWEN_API_KEY=your-dashscope-api-key
QWEN_MODEL=qwen-plus
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# 备用 LLM（DeepSeek，主力超时时自动切换）
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Embedding 模型（通义千问）
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_API_KEY=your-dashscope-api-key   # 与 Qwen 相同

# LLM 超时配置（秒）
LLM_TIMEOUT_SECONDS=30
LLM_FALLBACK_ENABLED=true

# ─── 并发限制 ─────────────────────────────────────────────
LLM_GLOBAL_CONCURRENCY=30    # 全局最多并发 LLM 请求数
LLM_TENANT_CONCURRENCY=5     # 每个租户最多并发 LLM 请求数

# ─── 缓存配置 ─────────────────────────────────────────────
SEMANTIC_CACHE_ENABLED=true
SEMANTIC_CACHE_THRESHOLD=0.95      # 相似度阈值
SEMANTIC_CACHE_TTL=86400           # 24小时（秒）
SESSION_CACHE_TTL=1800             # 30分钟空闲超时（秒）

# ─── 知识库配置 ───────────────────────────────────────────
UPLOAD_DIR=data/uploads            # 上传文件存储目录
CHUNK_SIZE_ZH=400                  # 中文分块大小（字符）
CHUNK_SIZE_EN=300                  # 英文分块大小（词）
CHUNK_OVERLAP=50                   # 分块重叠大小
RETRIEVAL_TOP_K=10                 # 检索 Top-K 数量
GRADER_THRESHOLD=0.6               # Grader 低分阈值，低于此值触发 re-retrieve

# ─── Widget 配置 ──────────────────────────────────────────
WIDGET_CDN_BASE_URL=http://localhost:8080   # 生产环境改为 CDN 地址
WIDGET_ALLOWED_ORIGINS=*                    # 生产环境改为白名单域名

# ─── 通知服务配置 ─────────────────────────────────────────
# 邮件（SMTP）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@yourproduct.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_NAME=智能客服平台

# 微信推送（预留，Phase 3 后实现）
# WECHAT_CORP_ID=
# WECHAT_AGENT_ID=
# WECHAT_SECRET=

# ─── 支付配置（Phase 3）─────────────────────────────────
# 微信支付
# WECHAT_PAY_MCH_ID=
# WECHAT_PAY_API_KEY=
# 支付宝
# ALIPAY_APP_ID=
# ALIPAY_PRIVATE_KEY=

# ─── 安全配置 ─────────────────────────────────────────────
BCRYPT_ROUNDS=12                   # bcrypt cost，勿调低
INVITATION_EXPIRE_DAYS=7
MAX_LOGIN_ATTEMPTS=5               # 连续失败次数，超过锁定15分钟
RATE_LIMIT_PER_TENANT_PER_MIN=300  # 每租户每分钟 API 请求上限
